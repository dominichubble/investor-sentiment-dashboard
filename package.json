{
  "name": "investor-sentiment-dashboard",
  "version": "1.0.0",
  "description": "Full-stack investor sentiment analysis dashboard",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --host localhost --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "cd frontend && npm install",
    "build:frontend": "cd frontend && npm run build",
    "start": "npm run dev",
    "test:backend": "cd backend && pytest",
    "lint:frontend": "cd frontend && npm run lint",
    "type-check:frontend": "cd frontend && npm run type-check"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "python": ">=3.11.0"
  }
}
