.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Data files (generated by pipeline — kept out of repo)
# Raw ingested data (JSON/CSV from APIs)
data/raw/**/*.json
data/raw/**/*.csv
data/raw/**/*.txt

# SQLite database (rebuilt by process_stock_sentiments.py)
data/db/*.db

# Legacy / removed directories
data/processed/
data/predictions/
data/stock_sentiments/

# Keep directory structure via .gitkeep
!data/raw/reddit/.gitkeep
!data/raw/news/.gitkeep
!data/raw/twitter/.gitkeep
!data/db/.gitkeep

# Generated explainability examples
**/lime_examples/

# Logs
logs/

# Notebook checkpoints
.ipynb_checkpoints/

# Frontend / Node.js
node_modules/
frontend/node_modules/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
