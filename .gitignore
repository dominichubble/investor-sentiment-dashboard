.env

# --- Virtual environments (never commit) ---
.venv/
venv/
env/
ENV/
.virtualenv/
pyvenv.cfg

# --- Coursework & university context (briefs, rubrics, submissions; keep local only) ---
*.pdf
*.docx
*.docm
*.pptx
*.xlsx
*rubric*.png
~$*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Data files (generated by pipeline — kept out of repo)
# Downloaded external corpora (e.g. Felix Drinkall Yahoo news .xz)
data/external/**/*.xz

# Raw ingested data (JSON/CSV from APIs)
data/raw/**/*.json
data/raw/**/*.csv
data/raw/**/*.txt

# Local SQLite / DB files under data/db (Neon is canonical; no DB file in repo)
data/db/*.db

# Legacy / removed directories
data/predictions/
data/stock_sentiments/

# Keep DB directory placeholder only
!data/db/.gitkeep

# Processed data — allow evaluation artifacts (LIME examples) through
data/processed/*
!data/processed/explanations/
data/processed/explanations/*
!data/processed/explanations/lime_examples/

# Logs
logs/

# Notebook checkpoints
.ipynb_checkpoints/

# Frontend / Node.js
node_modules/
frontend/node_modules/
frontend/.vite/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
.env
.env.local
.env.production
