# Reddit API Credentials
# Get these from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=investor-sentiment-dashboard/0.1 by your_username

# Twitter/X ingest (default: snscrape — no API key; often breaks when X changes GraphQL)
# TWITTER_INGEST_BACKEND=snscrape
#
# Official API (needs Project with v2 recent search access)
# TWITTER_INGEST_BACKEND=api
# TWITTER_BEARER_TOKEN=your_bearer_token_here
#
# Local CSV rows (Date,Tweet,Stock Name,...) — no network; default file: stock_tweets.csv at repo root
# TWITTER_INGEST_BACKEND=csv
# TWITTER_CSV_PATH=/path/to/tweets.csv
#
# Prefer API when TWITTER_BEARER_TOKEN is set, else snscrape
# TWITTER_INGEST_BACKEND=auto

# News API Credentials
# Get these from: https://newsapi.org/register
# Choose "Developer" plan (FREE) → Copy API key from dashboard
# Free tier: 100 requests/day, 1-month history, 100 articles per request
NEWS_API_KEY=your_newsapi_key_here

# Neon PostgreSQL Database
# Get your connection string from https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Financial News API (for future use)
