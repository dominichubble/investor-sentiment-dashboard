# Reddit API Credentials
# Get these from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=investor-sentiment-dashboard/0.1 by your_username

# Twitter/X ingest (default: snscrape — no API key; often breaks when X changes GraphQL)
# TWITTER_INGEST_BACKEND=snscrape
#
# Official API (needs Project with v2 recent search access)
# TWITTER_INGEST_BACKEND=api
# TWITTER_BEARER_TOKEN=your_bearer_token_here
#
# Local CSV rows (Date,Tweet,Stock Name,...) — no network; default file: stock_tweets.csv at repo root
# TWITTER_INGEST_BACKEND=csv
# TWITTER_CSV_PATH=/path/to/tweets.csv
#
# Prefer API when TWITTER_BEARER_TOKEN is set, else snscrape
# TWITTER_INGEST_BACKEND=auto

# News API Credentials
# Get these from: https://newsapi.org/register
# Choose "Developer" plan (FREE) → Copy API key from dashboard
# Free tier: 100 requests/day, 1-month history, 100 articles per request
NEWS_API_KEY=your_newsapi_key_here

# Neon PostgreSQL Database
# Get your connection string from https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Groq (free tier) — AI narrative summaries for ticker sentiment on Stock Analysis page
# https://console.groq.com/keys
GROQ_API_KEY=
# Optional overrides:
# GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
# SENTIMENT_NARRATIVE_MODEL=llama-3.1-8b-instant

# Financial News API (for future use)

# --- Production / enterprise (optional) ---
# Comma-separated browser origins for CORS (omit for localhost defaults).
# CORS_ALLOW_ORIGINS=https://app.yourcompany.com,https://www.yourcompany.com
#
# Require Bearer API key on all /api/* routes (omit or leave empty for open dev API).
# API_KEYS=your-long-random-key,another-key-for-partners
#
# Restrict Host header (comma-separated). Enables TrustedHostMiddleware.
# ALLOWED_HOSTS=api.yourcompany.com,localhost
#
# Send X-Frame-Options, nosniff, Referrer-Policy, Permissions-Policy (default: on).
# ENABLE_SECURITY_HEADERS=0

# --- Lean cloud API (optional) ---
# Install backend/requirements-lean.txt and set LEAN_API=1 for a small image: data,
# correlation, stock-quality, and Groq ticker narrative only. FinBERT/LIME return 503.
# LEAN_API=1
